# Ollama model — must be pulled first (see below)
# Low-latency options (recommended):
#   gemma2:2b       ~1.6 GB  fastest + good quality  (DEFAULT)
#   qwen2.5:1.5b    ~1.0 GB  smallest, very fast
#   phi3:mini       ~2.2 GB  strong reasoning, fast
#   llama3.2:3b     ~2.0 GB  good balance
# OLLAMA_MODEL=gemma2:2b
OLLAMA_MODEL=llama3:latest

# Ollama server URL (default is fine if running locally)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model — downloaded automatically by sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
