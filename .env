# HuggingFace token (required) — get one free at https://huggingface.co/settings/tokens
HF_TOKEN=

# HuggingFace model to use for generation (must support Inference API)
# Good options:
#   mistralai/Mistral-7B-Instruct-v0.2  (default, recommended)
#   HuggingFaceH4/zephyr-7b-beta
#   microsoft/Phi-3-mini-4k-instruct
#   google/gemma-7b-it
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2
HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# OLLAMA_MODEL=gemma2:2b
OLLAMA_MODEL=llama3:latest

# sentence-transformers embedding model (downloaded automatically, no token needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2
